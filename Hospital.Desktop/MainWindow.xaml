<Window x:Class="Hospital.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إدارة الموظفين" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        WindowStyle="None"
        WindowState="Maximized">

    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="نظام إدارة الموظفين" Foreground="White" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="الرئيسية" IsChecked="True" Command="{Binding NavCommand}" CommandParameter="Dashboard" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="الموظفين" Command="{Binding NavCommand}" CommandParameter="Employees" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="الأقسام" Command="{Binding NavCommand}" CommandParameter="Departments" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="الأجازات" Command="{Binding NavCommand}" CommandParameter="Leaves" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="الغيابات" Command="{Binding NavCommand}" CommandParameter="Absents" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="التنقلات" Command="{Binding NavCommand}" CommandParameter="Transfers" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="العناوين الوظيفية" Command="{Binding NavCommand}" CommandParameter="JobTitles" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="المستخدمين" Command="{Binding NavCommand}" CommandParameter="Users" FlowDirection="LeftToRight"/>
                <RadioButton Style="{StaticResource MenuButtonStyle}" Content="سجلات التدقيق" Command="{Binding NavCommand}" CommandParameter="AuditLogs" FlowDirection="LeftToRight"/>

                <Separator Background="#5D6D7E" Margin="10,20"/>

                <Button Style="{StaticResource LogoutButtonStyle}" Content="خروج" Click="Logout_Click" FlowDirection="LeftToRight"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                   Text="{Binding SelectedMenuTitle}" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Left"
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Foreground="#333"/>

                    <StackPanel Grid.Column="1" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Right">
                        <TextBlock Text="{Binding CurrentTime}" VerticalAlignment="Center" 
                       Margin="0,0,10,0" Foreground="#666" FontFamily="Consolas"/>
                        <Button Content="⚙" FontSize="20" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand" Margin="0,0,15,0" ToolTip="الإعدادات"/>

                        <Button Content="✕" Foreground="Red" FontSize="18" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand" Click="Logout_Click" ToolTip="خروج"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="20"/>
        </Grid>
    </Grid>
</Window>