<Window x:Class="Hospital.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إدارة الموظفين" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="FluentMenuButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" Margin="8,2" CornerRadius="6" SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal" Margin="15,10">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="16" VerticalAlignment="Center" Foreground="#A0A0A0" Margin="0,0,12,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D4E5F"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#D1D1D1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F3F3F3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#202020">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="إدارة الموارد البشرية" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,10">
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="الرئيسية" Tag="" IsChecked="True" Command="{Binding NavCommand}" CommandParameter="Dashboard"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="الموظفين" Tag="" Command="{Binding NavCommand}" CommandParameter="Employees"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="الأقسام" Tag="" Command="{Binding NavCommand}" CommandParameter="Departments"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="الأجازات" Tag="" Command="{Binding NavCommand}" CommandParameter="Leaves"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="الغيابات" Tag="" Command="{Binding NavCommand}" CommandParameter="Absents"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="التنقلات" Tag="" Command="{Binding NavCommand}" CommandParameter="Transfers"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="العناوين الوظيفية" Tag="" Command="{Binding NavCommand}" CommandParameter="JobTitles"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="المستخدمين" Tag="" Command="{Binding NavCommand}" CommandParameter="Users"/>
                        <RadioButton Style="{StaticResource FluentMenuButton}" Content="سجلات التدقيق" Tag="" Command="{Binding NavCommand}" CommandParameter="AuditLogs"/>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" 
        Click="Logout_Click" 
        Margin="15,10,15,25" 
        Padding="10,8"
        Background="Transparent" 
        BorderThickness="0" 
        Cursor="Hand"
        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="" 
                   FontFamily="Segoe MDL2 Assets" 
                   Foreground="#E74C3C" 
                   FontSize="22" 
                   VerticalAlignment="Center" 
                   Margin="0,0,12,0"/>

                        <TextBlock Text="تسجيل الخروج" 
                   Foreground="#E74C3C" 
                   FontSize="16" 
                   VerticalAlignment="Center" 
                   FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="4" Height="24" Background="#0078D4" CornerRadius="2" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding SelectedMenuTitle}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#F9F9F9" Padding="12,6" CornerRadius="6" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#666" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentTime}" Foreground="#333" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="18" Background="Transparent" 
                                BorderThickness="0" Foreground="#555" Cursor="Hand" Width="40" Height="40"/>

                        <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="16" Background="Transparent" 
                                BorderThickness="0" Foreground="#E74C3C" Cursor="Hand" Width="40" Height="40" Click="Logout_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="25" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <ContentControl Content="{Binding CurrentView}" Margin="5"/>
            </Border>
        </Grid>
    </Grid>
</Window>