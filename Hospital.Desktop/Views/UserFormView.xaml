<Window x:Class="Hospital.Desktop.Views.UserFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيانات المستخدم" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="اسم المستخدم (UserName):" Margin="0,5"/>
            <TextBox Text="{Binding User.UserName}" 
                     IsEnabled="{Binding IsAddMode}" 
                     Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="الاسم الكامل:" Margin="0,5"/>
            <TextBox Text="{Binding User.FullName}" 
                     IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
                     Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="الصلاحية:" Margin="0,5"/>
            <ComboBox ItemsSource="{Binding Roles}" 
                      SelectedItem="{Binding User.Role}"
                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
                      Margin="0,0,0,10"/>

            <StackPanel Visibility="{Binding IsAddMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="كلمة المرور:" Margin="0,5"/>
                <PasswordBox Padding="5" Margin="0,0,0,10"/>
            </StackPanel>

            <Separator Margin="0,10"/>

            <CheckBox Content="ربط هذا الحساب بموظف" 
                      IsChecked="{Binding LinkEmployee}"
                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
                      Margin="0,10"/>

            <ComboBox ItemsSource="{Binding Employees}"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding User.EmployeeId}"
                      IsEnabled="{Binding LinkEmployee}"
                      Margin="0,5,0,20">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsViewMode}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="حفظ البيانات" Command="{Binding SaveCommand}" 
                        Visibility="{Binding IsViewMode, Converter={StaticResource InverseBoolToVis}}"
                        Width="100" Height="35" Background="#2ECC71" Foreground="White"/>

                <Button Content="إغلاق" IsCancel="True" 
                        Width="100" Height="35" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>