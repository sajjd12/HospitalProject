<Window x:Class="Hospital.Desktop.Views.LeaveFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نموذج الإجازة" Height="500" Width="450" 
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="بيانات طلب الإجازة" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="الموظف صاحب الإجازة:"/>
            <ComboBox ItemsSource="{Binding Employees}" DisplayMemberPath="Name" SelectedValuePath="Id"
                      SelectedValue="{Binding Leave.EmployeeId}" IsEditable="True"
                      Text="{Binding EmpSearchText, UpdateSourceTrigger=PropertyChanged}"
                      IsDropDownOpen="{Binding IsEmpDropDownOpen}" Height="35" Margin="0,5,0,15"/>

            <TextBlock Text="الموظف البديل:"/>
            <ComboBox ItemsSource="{Binding SubEmployees}" DisplayMemberPath="Name" SelectedValuePath="Id"
                      SelectedValue="{Binding Leave.SubEmployeeId}" IsEditable="True"
                      Text="{Binding SubSearchText, UpdateSourceTrigger=PropertyChanged}"
                      IsDropDownOpen="{Binding IsSubDropDownOpen}" Height="35" Margin="0,5,0,15"/>

            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="من تاريخ:"/>
                    <DatePicker SelectedDate="{Binding Leave.StartDate}" Height="35" Margin="0,5"/>
                </StackPanel>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="إلى تاريخ:"/>
                    <DatePicker SelectedDate="{Binding Leave.EndDate}" Height="35" Margin="0,5"/>
                </StackPanel>
            </UniformGrid>

            <TextBlock Text="مدة الإجازة (أيام):" Margin="0,15,0,0"/>
            <TextBox Text="{Binding Leave.Duration}" Height="35" VerticalContentAlignment="Center" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button Content="حفظ البيانات" Command="{Binding SaveCommand}" Width="150" Height="40" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                <Button Content="إلغاء" IsCancel="True" Width="100" Height="40" Margin="10,0,0,0" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>