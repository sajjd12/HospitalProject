<UserControl x:Class="Hospital.Desktop.Views.AbsentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" Margin="15" CornerRadius="8" Padding="15">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="اسم الموظف:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="180" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="التاريخ:" FontSize="12" Foreground="Gray"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" Width="150" Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="الحالة:" FontSize="12" Foreground="Gray"/>
                    <ComboBox SelectedIndex="{Binding SelectedStatusFilter}" Width="120" Height="35">
                        <ComboBoxItem Content="الكل"/>
                        <ComboBoxItem Content="الفعال"/>
                        <ComboBoxItem Content="المحذوف"/>
                    </ComboBox>
                </StackPanel>

                <Button Content="إضافة غياب +" Command="{Binding AddCommand}" Background="#27AE60" Foreground="White" Width="130" Height="35" BorderThickness="0" Margin="10,15,0,0"/>
                <Button Content="تحديث" Command="{Binding RefreshCommand}" Background="#3498DB" Foreground="White" Width="80" Height="35" BorderThickness="0" Margin="10,15,0,0"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Absents}" Margin="15,0,15,15" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="50" FontSize="14">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ت" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="الموظف" Binding="{Binding EmployeeName}" Width="2*"/>
                <DataGridTextColumn Header="تاريخ الغياب" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="*"/>
                <DataGridTemplateColumn Header="الإجراءات" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}"
                                    Content="{Binding IsDeleted, Converter={StaticResource DeleteRestoreConverter}}"
                                    Foreground="{Binding IsDeleted, Converter={StaticResource DeleteRestoreConverter}, ConverterParameter=Color}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" Background="White" Margin="15,0,15,15" CornerRadius="8" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="السابق" Command="{Binding PrevPageCommand}" Width="80" Margin="5" Background="#BDC3C7" BorderThickness="0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="صفحة " Foreground="Gray"/>
                    <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text=" من " Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>

                <Button Content="التالي" Command="{Binding NextPageCommand}" Width="80" Margin="5" Background="#BDC3C7" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>