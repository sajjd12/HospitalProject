<UserControl x:Class="Hospital.Desktop.Views.AbsentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Hospital.Desktop.Converters"
             FlowDirection="RightToLeft"
             Background="#F8FAFC"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:DeleteRestoreConverter x:Key="DeleteRestoreConverter"/>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="اسم الموظف" Style="{StaticResource FilterLabel}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Style="{StaticResource ModernInput}" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="التاريخ" Style="{StaticResource FilterLabel}"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" Width="160" Style="{StaticResource ModernInput}"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="حالة القيد" Style="{StaticResource FilterLabel}"/>
                    <ComboBox SelectedIndex="{Binding SelectedStatusFilter}" Width="130" Style="{StaticResource ModernInput}">
                        <ComboBoxItem Content="عرض الكل"/>
                        <ComboBoxItem Content="السجلات الفعالة"/>
                        <ComboBoxItem Content="الأرشيف"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                    <Button Content="+ إضافة غياب" Command="{Binding AddCommand}" Background="#2563EB" Foreground="White" Width="130" Height="38" FontWeight="SemiBold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="تحديث" Command="{Binding RefreshCommand}" Background="White" Foreground="#64748B" Width="80" Height="38" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Absents}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      RowHeight="55" 
                      BorderThickness="0" 
                      Background="Transparent"
                      GridLinesVisibility="None"
                      HorizontalGridLinesBrush="#F1F5F9">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ت" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="اسم الموظف" Binding="{Binding EmployeeName}" Width="2*"/>
                    <DataGridTemplateColumn Header="تاريخ الغياب" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy / MM / dd}'}" VerticalAlignment="Center" Foreground="#334155"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="الإجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}"
                                        Content="{Binding IsDeleted, Converter={StaticResource DeleteRestoreConverter}}"
                                        Foreground="{Binding IsDeleted, Converter={StaticResource DeleteRestoreConverter}, ConverterParameter=Color}"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="السابق" Command="{Binding PrevPageCommand}" Width="90" Height="35" Background="#F1F5F9" Foreground="#475569" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Border Background="#F8FAFC" CornerRadius="6" Margin="25,0" Padding="15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="صفحة " Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#2563EB" FontSize="14"/>
                        <TextBlock Text=" من " Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#1E293B" FontSize="14"/>
                    </StackPanel>
                </Border>

                <Button Content="التالي" Command="{Binding NextPageCommand}" Width="90" Height="35" Background="#F1F5F9" Foreground="#475569" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>