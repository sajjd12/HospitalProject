<UserControl x:Class="Hospital.Desktop.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" Margin="15,15,15,5" CornerRadius="8" Padding="15">
            <StackPanel Orientation="Horizontal">
                <Button Content="تحديث القائمة" Command="{Binding RefreshCommand}" Style="{StaticResource ActionButtonStyle}" Background="#3498DB" Foreground="White"/>
                <Button Content="إضافة موظف" Command="{Binding AddEmployeeCommand}" Margin="10,0" Style="{StaticResource ActionButtonStyle}" Background="#2ECC71" Foreground="White"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="15,5,15,15">
            <DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowHeight="50">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="المعرف" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="اسم الموظف" Binding="{Binding Name}" Width="1.5*"/>
                    <DataGridTextColumn Header="الجنس" Binding="{Binding Gender, Converter={StaticResource GenderConverter}}" Width="80"/>
                    <DataGridTextColumn Header="تاريخ الميلاد" Binding="{Binding BirthDate}" Width="*"/>
                    <DataGridTextColumn Header="تاريخ التعيين" Binding="{Binding HireDate}" Width="*"/>
                    <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="*"/>

                    <DataGridTemplateColumn Header="الإجراءات" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="عرض" Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#3498DB" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    <TextBlock Text=" | " VerticalAlignment="Center" Foreground="#DDD"/>
                                    <Button Content="تعديل" Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#F39C12" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    <TextBlock Text=" | " VerticalAlignment="Center" Foreground="#DDD"/>
                                    <Button Content="حذف" Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#E74C3C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</UserControl>