<Window x:Class="Hospital.Desktop.Views.TransferDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل الأمر الإداري" Height="400" Width="500" WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft" ResizeMode="NoResize">
    <Grid Margin="20" Background="#FDFDFD">
        <StackPanel>
            <Border BorderBrush="#3498DB" BorderThickness="0,0,0,2" Margin="0,0,0,20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{Binding EmployeeName}" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="{Binding TransferDate, StringFormat='تاريخ التنفيذ: {0}'}" Foreground="Gray" Margin="0,5"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AdOrderNumber}" HorizontalAlignment="Right" VerticalAlignment="Center" 
                               FontSize="14" Foreground="#E67E22" FontWeight="Bold"/>
                </Grid>
            </Border>

            <UniformGrid Columns="2">
                <GroupBox Header="قبل النقل (سابقاً)" Margin="5" Padding="10" Foreground="#E74C3C">
                    <StackPanel>
                        <TextBlock Text="القسم:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OldDepartmentName}" Margin="0,5,0,15" FontSize="14"/>

                        <TextBlock Text="نوع الدوام:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OldShiftType, Converter={StaticResource ShiftTypeConverter}}" FontSize="14"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="بعد النقل (حالياً)" Margin="5" Padding="10" Foreground="#27AE60">
                    <StackPanel>
                        <TextBlock Text="القسم:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NewDepartmentName}" Margin="0,5,0,15" FontSize="14"/>

                        <TextBlock Text="نوع الدوام:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NewShiftType, Converter={StaticResource ShiftTypeConverter}}" FontSize="14"/>
                    </StackPanel>
                </GroupBox>
            </UniformGrid>

            <Button Content="إغلاق النافذة" IsCancel="True" Margin="0,20,0,0" Height="35" Width="120" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>