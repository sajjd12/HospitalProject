<UserControl x:Class="Hospital.Desktop.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Margin="15,15,15,5" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
            </Border.Effect>

            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="تحديث القائمة" Command="{Binding RefreshCommand}" 
                        Padding="15,7" Background="#3498DB" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>

                <Button Content="إضافة مستخدم" 
        Command="{Binding AddUserCommand}" 
        Margin="10,0" Padding="15,7" 
        Background="#2ECC71" Foreground="White" 
        FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>

                <Separator Margin="15,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>

                <StackPanel Margin="10,0">
                    <TextBlock Text="حالة الحساب" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding IsActiveFilter}" SelectedValuePath="Tag" Width="140" Height="30">
                        <ComboBoxItem Content="الكل (افتراضي)" Tag="{x:Null}"/>
                        <ComboBoxItem Content="النشطين فقط" Tag="True"/>
                        <ComboBoxItem Content="المعطلين فقط" Tag="False"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="15,0">
                    <TextBlock Text="عرض الأرشيف" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding IsDeletedFilter}" SelectedValuePath="Tag" Width="140" Height="30">
                        <ComboBoxItem Content="الكل" Tag="{x:Null}"/>
                        <ComboBoxItem Content="المحذوفين فقط" Tag="True"/>
                        <ComboBoxItem Content="غير المحذوفين (افتراضي)" Tag="False"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="1" Margin="15,5,15,15">
            <DataGrid ItemsSource="{Binding Users}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single" 
                      SelectionUnit="FullRow"
                      Background="White" 
                      BorderThickness="1" 
                      BorderBrush="#E0E6ED"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0F2F5"
                      RowHeight="50">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Foreground" Value="#2C3E50"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#3498DB"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F8FF"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding UserName}" Width="*"/>
                    <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding FullName}" Width="1.5*"/>
                    <DataGridTextColumn Header="الصلاحية" Binding="{Binding Role}" Width="*"/>

                    <DataGridTemplateColumn Header="الحالة" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}" 
                                        CornerRadius="12" Padding="10,3" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding IsActive, Converter={StaticResource BooleanToStatusConverter}}" 
                                               Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="الإجراءات" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <Button Content="عرض التفاصيل" 
            Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0" Foreground="#3498DB" FontWeight="SemiBold" Cursor="Hand"/>

                                    <TextBlock Text=" | " Foreground="#DDD" VerticalAlignment="Center"/>

                                    <Button Content="تعديل" 
            Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0" Foreground="#3498DB" FontWeight="SemiBold" Cursor="Hand"/>

                                    <TextBlock Text=" | " Foreground="#DDD" VerticalAlignment="Center"/>

                                    <Button Content="حذف" 
            Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0" Foreground="#E74C3C" FontWeight="SemiBold" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                         Foreground="#3498DB" Background="Transparent" BorderThickness="0"/>
        </Grid>
    </Grid>
</UserControl>