<UserControl x:Class="Hospital.Desktop.Views.TransferLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#F8FAFC"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ إجراء نقل جديد" 
                            Command="{Binding NewTransferCommand}" 
                            Style="{StaticResource ModernBtn}"
                            Background="#2563EB" 
                            Foreground="White" 
                            Width="160">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="#2563EB"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="بحث باسم الموظف:" 
                               VerticalAlignment="Center" 
                               Foreground="#64748B" 
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource SearchTextBox}"
                             Width="280"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Logs}" 
                      SelectedItem="{Binding SelectedLog, Mode=TwoWay}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="55"
                      BorderThickness="0"
                      Background="Transparent"
                      GridLinesVisibility="None"
                      HorizontalGridLinesBrush="#F1F5F9">

                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding ViewDetailsCommand}" 
                                  CommandParameter="{Binding SelectedLog}"/>
                </DataGrid.InputBindings>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="الموظف" Binding="{Binding EmployeeName}" Width="1.5*"/>
                    <DataGridTextColumn Header="من قسم" Binding="{Binding OldDepartmentName}" Width="1.2*"/>
                    <DataGridTextColumn Header="إلى قسم" Binding="{Binding NewDepartmentName}" Width="1.2*"/>
                    <DataGridTemplateColumn Header="رقم الكتاب" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AdOrderNumber}" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold" 
                                           Foreground="#B45309"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="تاريخ النقل" Binding="{Binding TransferDate, StringFormat=yyyy/MM/dd}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="السابق" 
                        Command="{Binding PrevPageCommand}" 
                        Style="{StaticResource ModernBtn}"
                        Width="90" 
                        Background="#F1F5F9" 
                        Foreground="#475569"/>

                <Border Background="#F8FAFC" CornerRadius="6" Margin="25,0" Padding="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="صفحة " Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#2563EB" FontSize="14"/>
                        <TextBlock Text=" من " Foreground="#94A3B8" FontSize="13" Margin="5,0"/>
                        <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#1E293B" FontSize="14"/>
                    </StackPanel>
                </Border>

                <Button Content="التالي" 
                        Command="{Binding NextPageCommand}" 
                        Style="{StaticResource ModernBtn}"
                        Width="90" 
                        Background="#F1F5F9" 
                        Foreground="#475569"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>