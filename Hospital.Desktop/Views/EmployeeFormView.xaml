<Window x:Class="Hospital.Desktop.Views.EmployeeFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيانات الموظف بالتفصيل" Height="650" Width="650"
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft"
        Background="#F3F3F3"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="15" Background="White" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F9F9F9" Padding="20,15" CornerRadius="12,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" Foreground="#0078D4" Margin="0,0,12,0"/>
                    <TextBlock Text="إدارة ملف الموظف" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,10">
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,15">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Foreground="#0078D4" Margin="0,0,10,0"/>
                        <TextBlock Text="المعلومات الأساسية" Style="{StaticResource SectionHeaderStyle}"/>
                    </StackPanel>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="5">
                            <TextBlock Text="الاسم الكامل:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding em.Name}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="الجنس:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding em.Gender}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38" VerticalContentAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource GenderConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="تاريخ الميلاد:" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding em.BirthDate, Converter={StaticResource DateOnlyConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                        IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="رقم الهاتف:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding em.PhoneNumber}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}"/>
                        </StackPanel>
                    </UniformGrid>

                    <Separator Margin="0,20" Background="#F0F0F0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Foreground="#0078D4" Margin="0,0,10,0"/>
                        <TextBlock Text="المعلومات الوظيفية" Style="{StaticResource SectionHeaderStyle}"/>
                    </StackPanel>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="5">
                            <TextBlock Text="القسم:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Departments}" SelectedValuePath="Id" DisplayMemberPath="Name" 
                                      SelectedValue="{Binding em.DepartmentId , Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsAddMode}" Height="38" VerticalContentAlignment="Center"/>
                            <TextBlock Text="* استخدم نظام التنقلات لتغيير القسم" Foreground="#E74C3C" FontSize="10" Margin="0,3,0,0"
                                       Visibility="{Binding IsAddMode, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="المسمى الوظيفي:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding JobTitles}" SelectedValuePath="Id" DisplayMemberPath="Title" 
                                      SelectedValue="{Binding em.JobTitleId}"
                                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="نوع المناوبة:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ShiftTypes}" SelectedItem="{Binding em.ShiftType}" 
                                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38" VerticalContentAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource ShiftTypeConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="تاريخ التعيين:" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding em.HireDate, Converter={StaticResource DateOnlyConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                        IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38"/>
                        </StackPanel>
                    </UniformGrid>

                    <Separator Margin="0,20" Background="#F0F0F0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Foreground="#0078D4" Margin="0,0,10,0"/>
                        <TextBlock Text="المؤهلات والإجازات" Style="{StaticResource SectionHeaderStyle}"/>
                    </StackPanel>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="5">
                            <TextBlock Text="التحصيل الدراسي:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Certificates}" SelectedItem="{Binding em.CertificateType}" 
                                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38" VerticalContentAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource CertificateConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="الحالة الوظيفية:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding JobStatuses}" SelectedItem="{Binding em.JobStatus}" 
                                      IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Height="38" VerticalContentAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource JobStatusConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="الرصيد الحالي (أيام):" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding em.LeaveBalance}" FontWeight="Bold" Foreground="#2980B9" 
                                     IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <TextBlock Text="رقم كارت الإجازات:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding em.LeaveCardNumber}" 
                                     IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="5,15,5,5">
                        <TextBlock Text="العنوان السكني الكامل:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding em.Address}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" 
                                 VerticalContentAlignment="Top" Padding="10"
                                 IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F9F9F9" Padding="20" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SaveCommand}" Width="160" Height="42" Background="#0078D4" Foreground="White" BorderThickness="0" 
                            Visibility="{Binding IsViewMode, Converter={StaticResource InverseBoolToVis}}" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="حفظ التغييرات" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button IsCancel="True" Width="100" Height="42" Margin="10,0,0,0" Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="إغلاق" VerticalAlignment="Center" Foreground="#666"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>