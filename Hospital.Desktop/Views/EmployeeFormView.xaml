<Window x:Class="Hospital.Desktop.Views.EmployeeFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بيانات الموظف بالتفصيل" Height="650" Width="600"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="المعلومات الأساسية" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#2C3E50"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="5">
                        <TextBlock Text="الاسم الكامل:"/>
                        <TextBox Text="{Binding em.Name}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Padding="5" Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="الجنس:"/>
                        <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding em.Gender}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Margin="0,5">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource GenderConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="تاريخ الميلاد:"/>
                        <DatePicker SelectedDate="{Binding em.BirthDate, Converter={StaticResource DateOnlyConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
            IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
            Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="رقم الهاتف:"/>
                        <TextBox Text="{Binding em.PhoneNumber}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Padding="5" Margin="0,5"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="المعلومات الوظيفية" FontWeight="Bold" FontSize="16" Margin="0,15,0,10" Foreground="#2C3E50"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="5">
                        <TextBlock Text="القسم:"/>
                        <ComboBox ItemsSource="{Binding Departments}" 
              SelectedValuePath="Id" 
              DisplayMemberPath="Name" 
              SelectedValue="{Binding em.DepartmentId , Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}"
              IsEnabled="{Binding IsAddMode}" 
              Margin="0,5">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="ToolTip" Value="لا يمكن تغيير القسم من هنا، يرجى استخدام نظام التنقلات."/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <TextBlock Text="* لتغيير القسم، استخدم قسم التنقلات" 
               Foreground="#E74C3C" 
               FontSize="10" 
               Visibility="{Binding IsAddMode, Converter={StaticResource InverseBoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="المسمى الوظيفي:"/>
                        <ComboBox ItemsSource="{Binding JobTitles}" 
          SelectedValuePath="Id" 
          DisplayMemberPath="Title" 
          SelectedValue="{Binding em.JobTitleId}"
          IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
          Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="نوع المناوبة:"/>
                        <ComboBox ItemsSource="{Binding ShiftTypes}" SelectedItem="{Binding em.ShiftType}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Margin="0,5">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource ShiftTypeConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="تاريخ التعيين:"/>
                        <DatePicker SelectedDate="{Binding em.HireDate, Converter={StaticResource DateOnlyConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
            IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" 
            Margin="0,5"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="المؤهلات والحالة" FontWeight="Bold" FontSize="16" Margin="0,15,0,10" Foreground="#2C3E50"/>

                <UniformGrid Columns="2">
                    <StackPanel Margin="5">
                        <TextBlock Text="التحصيل الدراسي:"/>
                        <ComboBox ItemsSource="{Binding Certificates}" SelectedItem="{Binding em.CertificateType}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Margin="0,5">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CertificateConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="الحالة الوظيفية:"/>
                        <ComboBox ItemsSource="{Binding JobStatuses}" SelectedItem="{Binding em.JobStatus}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Margin="0,5">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource JobStatusConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="5">
                    <TextBlock Text="العنوان:"/>
                    <TextBox Text="{Binding em.Address}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBool}}" Padding="5" Height="60" TextWrapping="Wrap" Margin="0,5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="حفظ البيانات" Command="{Binding SaveCommand}" Width="150" Height="40" Background="#2ECC71" Foreground="White" BorderThickness="0" Visibility="{Binding IsViewMode, Converter={StaticResource InverseBoolToVis}}"/>
            <Button Content="إغلاق" IsCancel="True" Width="100" Height="40" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>