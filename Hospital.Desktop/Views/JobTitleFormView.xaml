<Window x:Class="Hospital.Desktop.Views.JobTitleFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدارة العناوين الوظيفية" 
        Height="230" Width="400" 
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft" 
        ResizeMode="NoResize"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="اسم العنوان الوظيفي" 
                   FontWeight="SemiBold" 
                   Foreground="#64748B" 
                   FontSize="13" 
                   Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" 
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                 Style="{StaticResource ModernTextBox}"
                 Height="42"
                 BorderThickness="1.5">
            <TextBox.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" Color="Black"/>
            </TextBox.Effect>
        </TextBox>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Bottom">

            <Button Content="حفظ العنوان" 
                    Command="{Binding SaveCommand}" 
                    Style="{StaticResource PrimaryBtn}" 
                    Background="#2563EB" 
                    Foreground="White" 
                    Width="120"
                    Height="40"/>

            <Button Content="إلغاء" 
                    IsCancel="True" 
                    Style="{StaticResource PrimaryBtn}" 
                    Background="Transparent" 
                    Foreground="#64748B" 
                    BorderThickness="1"
                    BorderBrush="#E2E8F0"
                    Margin="12,0,0,0" 
                    Width="100"
                    Height="40"/>
        </StackPanel>
    </Grid>
</Window>