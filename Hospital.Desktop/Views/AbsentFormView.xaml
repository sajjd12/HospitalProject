<Window x:Class="Hospital.Desktop.Views.AbsentFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل غياب جديد" 
        Height="400" Width="450" 
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft" 
        ResizeMode="NoResize"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="البحث عن الموظف" Style="{StaticResource FieldLabel}"/>
            <ComboBox ItemsSource="{Binding Employees}" 
                      DisplayMemberPath="Name" 
                      SelectedValuePath="Id" 
                      SelectedValue="{Binding Absent.EmployeeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                      IsDropDownOpen="{Binding IsSelecting}"
                      IsEditable="True" 
                      Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                      StaysOpenOnEdit="True"
                      Style="{StaticResource ModernInput}"/>

            <TextBlock Text="* يرجى إدخال 3 أحرف على الأقل لبدء البحث" 
                       FontSize="11" 
                       Foreground="#94A3B8" 
                       Margin="0,6,0,0"/>

            <TextBlock Text="تاريخ الغياب" 
                       Style="{StaticResource FieldLabel}" 
                       Margin="0,20,0,8"/>

            <DatePicker SelectedDate="{Binding Absent.Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Style="{StaticResource ModernInput}"
                        BorderThickness="1"/>

            <Grid Margin="0,40,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        Content="إتمام تسجيل الغياب" 
                        Command="{Binding SaveCommand}" 
                        Style="{StaticResource PrimaryBtn}" 
                        Margin="0,0,10,0"/>

                <Button Grid.Column="1" 
                        Content="إلغاء" 
                        IsCancel="True" 
                        Style="{StaticResource SecondaryBtn}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>