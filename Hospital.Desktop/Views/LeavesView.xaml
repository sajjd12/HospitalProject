<UserControl x:Class="Hospital.Desktop.Views.LeavesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#F8FAFC"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="اسم الموظف" Style="{StaticResource FilterLabel}"/>
                    <TextBox Text="{Binding SearchEmployee, UpdateSourceTrigger=PropertyChanged}" Width="180" Style="{StaticResource ModernInput}" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="اسم البديل" Style="{StaticResource FilterLabel}"/>
                    <TextBox Text="{Binding SearchSubEmployee, UpdateSourceTrigger=PropertyChanged}" Width="180" Style="{StaticResource ModernInput}" Padding="8,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="التاريخ" Style="{StaticResource FilterLabel}"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" Width="150" Style="{StaticResource ModernInput}"/>
                </StackPanel>

                <Button Content="+ إضافة إجازة" 
                        Command="{Binding AddCommand}" 
                        Background="#2563EB" Foreground="White" 
                        Width="130" Height="38" 
                        FontWeight="SemiBold" BorderThickness="0" 
                        Margin="10,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Leaves}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      RowHeight="55" 
                      BorderThickness="0" 
                      Background="Transparent"
                      GridLinesVisibility="None"
                      HorizontalGridLinesBrush="#F1F5F9">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم الموظف" Binding="{Binding EmployeeName}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="الرصيد" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#EFF6FF" CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentBalance}" Foreground="#2563EB" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="الموظف البديل" Binding="{Binding SubEmployeeName}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="المدة" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Duration, StringFormat='{}{0} يوم'}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="من تاريخ" Binding="{Binding StartDate, StringFormat=yyyy/MM/dd}" Width="110"/>
                    <DataGridTextColumn Header="إلى تاريخ" Binding="{Binding EndDate, StringFormat=yyyy/MM/dd}" Width="110"/>

                    <DataGridTemplateColumn Header="الإجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="تعديل" 
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Foreground="#2563EB" Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                                    <Separator Width="1" Height="15" Margin="8,0" Background="#E2E8F0"/>

                                    <Button Content="حذف" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Foreground="#EF4444" Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="10" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="السابق" Command="{Binding PrevPageCommand}" Width="90" Height="35" Background="#F1F5F9" Foreground="#475569" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Border Background="#F8FAFC" CornerRadius="6" Margin="25,0" Padding="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="صفحة " Foreground="#94A3B8" FontSize="13"/>
                        <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#2563EB" FontSize="14"/>
                        <TextBlock Text=" من " Foreground="#94A3B8" FontSize="13" Margin="5,0"/>
                        <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#1E293B" FontSize="14"/>
                    </StackPanel>
                </Border>

                <Button Content="التالي" Command="{Binding NextPageCommand}" Width="90" Height="35" Background="#F1F5F9" Foreground="#475569" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>