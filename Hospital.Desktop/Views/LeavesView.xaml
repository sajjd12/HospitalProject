<UserControl x:Class="Hospital.Desktop.Views.LeavesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" Margin="15" CornerRadius="8" Padding="15">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="اسم الموظف:" FontSize="11" Foreground="Gray"/>
                    <TextBox Text="{Binding SearchEmployee, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="اسم البديل:" FontSize="11" Foreground="Gray"/>
                    <TextBox Text="{Binding SearchSubEmployee, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="التاريخ:" FontSize="11" Foreground="Gray"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" Width="140" Height="32"/>
                </StackPanel>

                <Button Content="إضافة إجازة +" Command="{Binding AddCommand}" Background="#27AE60" Foreground="White" Width="120" Height="35" BorderThickness="0" Margin="10,12,0,0"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Leaves}" Margin="15,0,15,5" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="50">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="الموظف" Binding="{Binding EmployeeName}" Width="1.5*"/>
                <DataGridTextColumn Header="الرصيد" Binding="{Binding CurrentBalance}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#2980B9"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="البديل" Binding="{Binding SubEmployeeName}" Width="1.5*"/>
                <DataGridTextColumn Header="المدة" Binding="{Binding Duration}" Width="60"/>
                <DataGridTextColumn Header="من تاريخ" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="إلى تاريخ" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTemplateColumn Header="إجراءات" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="🗑️" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" Margin="15,0,15,15" CornerRadius="8" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="السابق" Command="{Binding PrevPageCommand}" Width="70" Height="30" Background="#BDC3C7" BorderThickness="0"/>
                <TextBlock VerticalAlignment="Center" Margin="20,0">
                    <Run Text="صفحة " Foreground="Gray"/>
                    <Run Text="{Binding CurrentPage}" FontWeight="Bold"/>
                    <Run Text=" من " Foreground="Gray"/>
                    <Run Text="{Binding TotalPages}" FontWeight="Bold"/>
                </TextBlock>
                <Button Content="التالي" Command="{Binding NextPageCommand}" Width="70" Height="30" Background="#BDC3C7" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>