<Window x:Class="Hospital.Desktop.Views.AbsentDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل سجل الغياب" Height="350" Width="480" 
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft" 
        ResizeMode="NoResize"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding EmployeeName}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#1E293B"/>
                    <TextBlock Text="تفاصيل سجل الغياب الرسمي" 
                               Foreground="#64748B" 
                               FontSize="13" 
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Background="#F1F5F9" 
                        CornerRadius="6" 
                        Padding="10,5" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding Id, StringFormat='رقم القيد: {0}'}" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#475569"/>
                </Border>
            </Grid>
            <Separator Margin="0,15,0,0" Background="#E2E8F0" Height="1"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2">
            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="تاريخ الغياب" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy / MM / dd}'}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#334155"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="حالة السجل" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border CornerRadius="6" Padding="12,5" HorizontalAlignment="Left">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeleted}" Value="False">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                        <Setter Property="Background" Value="#FEE2E2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock FontWeight="Bold" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="False">
                                            <Setter Property="Text" Value="● فعال "/>
                                            <Setter Property="Foreground" Value="#166534"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                            <Setter Property="Text" Value="● سجل محذوف"/>
                                            <Setter Property="Foreground" Value="#991B1B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Button Grid.Row="2" 
                Content="إغلاق النافذة" 
                IsCancel="True" 
                Height="45" 
                Width="140" 
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Background="#64748B" 
                Foreground="White" 
                FontWeight="SemiBold"
                Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
            <Button.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Button.Effect>
        </Button>
    </Grid>
</Window>