<Window x:Class="Hospital.Desktop.Views.LeaveDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل الإجازة" Height="480" Width="480" 
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft"
        Background="#F8FAFC"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="تفاصيل الإجازة المسجلة" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="معلومات الموظف والبديل وفترة الاجازة" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            <Separator Margin="0,15,0,0" Background="#E2E8F0" Height="1"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="اسم الموظف المجاز" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding EmployeeName}" Grid.Column="1" Margin="20,8,0,8" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>

                <TextBlock Text="الموظف البديل" Grid.Row="1" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SubEmployeeName}" Grid.Row="1" Grid.Column="1" Margin="20,8,0,8" FontSize="14" Foreground="#334155"/>

                <TextBlock Text="فترة الإجازة" Grid.Row="2" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="20,8,0,8">
                    <TextBlock Text="{Binding StartDate, StringFormat=yyyy / MM / dd}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                    <TextBlock Text="←" Margin="10,0" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding EndDate, StringFormat=yyyy / MM / dd}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                </StackPanel>

                <TextBlock Text="المدة الإجمالية" Grid.Row="3" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left" Margin="20,8,0,8" Background="#FFF7ED" CornerRadius="6" Padding="12,5">
                    <TextBlock Text="{Binding Duration, StringFormat='{}{0} أيام'}" FontSize="14" FontWeight="Bold" Foreground="#EA580C"/>
                </Border>
            </Grid>
        </Border>

        <Button Grid.Row="2" 
                Content="إغلاق" 
                IsCancel="True" 
                Width="120" 
                Height="42" 
                Margin="0,20,0,0" 
                Background="#64748B" 
                Foreground="White" 
                FontWeight="SemiBold"
                BorderThickness="0"
                Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>