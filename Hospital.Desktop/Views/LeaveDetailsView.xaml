<Window x:Class="Hospital.Desktop.Views.LeaveDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل الإجازة" Height="380" Width="450" 
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft">

    <Border Padding="25" Background="White">
        <StackPanel>
            <TextBlock Text="تفاصيل الإجازة المسجلة" FontSize="20" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,15"/>
            <Separator Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="اسم الموظف:" Grid.Row="0" Margin="0,10" FontWeight="Bold"/>
                <TextBlock Text="{Binding EmployeeName}" Grid.Row="0" Grid.Column="1" Margin="10,10" FontSize="16"/>

                <TextBlock Text="الموظف البديل:" Grid.Row="1" Margin="0,10" FontWeight="Bold"/>
                <TextBlock Text="{Binding SubEmployeeName}" Grid.Row="1" Grid.Column="1" Margin="10,10"/>

                <TextBlock Text="فترة الإجازة:" Grid.Row="2" Margin="0,10" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="10,10">
                    <TextBlock Text="{Binding StartDate, StringFormat=yyyy/MM/dd}"/>
                    <TextBlock Text="  إلى  " Foreground="Gray"/>
                    <TextBlock Text="{Binding EndDate, StringFormat=yyyy/MM/dd}"/>
                </StackPanel>

                <TextBlock Text="المدة الإجمالية:" Grid.Row="3" Margin="0,10" FontWeight="Bold"/>
                <TextBlock Text="{Binding Duration, StringFormat='{}{0} أيام'}" Grid.Row="3" Grid.Column="1" Margin="10,10" Foreground="#E67E22" FontWeight="Bold"/>
            </Grid>

            <Button Content="إغلاق النافذة" IsCancel="True" Width="120" Height="40" Margin="0,30,0,0" Background="#34495E" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>